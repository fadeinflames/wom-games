{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wom-platform.local/schemas/wom.scenario.v1.json",
  "title": "WOM Scenario Import v1",
  "type": "object",
  "required": ["scenarios"],
  "properties": {
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "title",
          "summary",
          "type",
          "difficulty",
          "durationMin",
          "contextJson",
          "eventsJson",
          "hintsJson",
          "actionsJson"
        ],
        "properties": {
          "title": { "type": "string", "minLength": 3 },
          "summary": { "type": "string", "minLength": 10 },
          "type": { "type": "string", "minLength": 3 },
          "difficulty": { "type": "string", "enum": ["JUNIOR", "MIDDLE", "SENIOR"] },
          "durationMin": { "type": "integer", "minimum": 5, "maximum": 180 },
          "contextJson": { "type": "object" },
          "eventsJson": { "type": "array" },
          "hintsJson": { "type": "array" },
          "actionsJson": { "type": "array" },
          "gmScriptJson": { "type": ["object", "null"] }
        }
      }
    }
  }
}
